# Phase 6: test サービス専用環境変数 (port 3101).
# prod (.env) と区別するため、改修側 (Phase 0-5) の既定値を明示する。
# docker compose --profile test up -d で起動。

# レンダラ実装の選択 (NFR-06)。test 環境は Programmatic_API を主検証経路とする。
RENDERER_MODE=programmatic

# SVG ルートの CSS padding は無効化 (C-H-02 と整合)。
# BEAUTIFUL_DEFAULTS の flowchart.diagramPadding=0 と二重で防御。
MERMAID_PADDING=0

# 親 API 互換のタイムアウト/サイズ上限。
DEFAULT_TIMEOUT_MS=8000
MAX_CODE_SIZE=51200
PNG_RENDER_SCALE=3

# Browser_Pool / RateLimiter (Phase 1/3 で導入された定数の test 既定値).
BROWSER_POOL_SIZE=4
RATE_LIMIT_MAX_INFLIGHT=15
RATE_LIMIT_RETRY_AFTER_MS=3000
POOL_QUEUE_MAX=20
POOL_WAIT_TIMEOUT_MS=3000
POOL_RETRY_AFTER_MS=5000

# Browser/Context recycle 閾値 (C-P-02).
MAX_RENDERS_PER_CONTEXT=100
MAX_RENDERS_PER_BROWSER=1000
MAX_BROWSER_AGE_MS=3600000

# timeout 上限 (C-S-06).
MAX_TIMEOUT_MS=30000
